<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f172a;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 500px;
            margin: 40px auto;
            background: #1e293b;
            border-radius: 24px;
            overflow: hidden;
            border: 2px solid #334155;
            text-align: center;
            color: #f8fafc;
        }

        .badge-circle {
            width: 120px;
            height: 120px;
            background: #334155;
            border-radius: 50%;
            margin: 40px auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            border: 4px solid;
        }

        .content {
            padding: 0 40px 40px;
        }

        .badge-name {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .congrats {
            color: #94a3b8;
            font-size: 16px;
            margin-bottom: 30px;
        }

        .btn {
            display: inline-block;
            padding: 14px 28px;
            background: #4A6CF7;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: bold;
            box-shadow: 0 4px 14px rgba(74, 108, 247, 0.4);
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="badge-circle" border="border-color: <%= badgeColor %>;">
            🏅
        </div>
        <div class="content">
            <div class="badge-name" border="color: <%= badgeColor %>;">
                <%= badgeName %>
            </div>
            <p class="congrats">Congratulations, <strong>
                    <%= name %>
                </strong>! You've just unlocked a new achievement on your profile.</p>

            <p style="color: #cbd5e1; margin-bottom: 30px;">Your dedication is paying off. Keep it up to unlock more
                exclusive rewards!</p>

            <a href="https://yourstore.com/profile" class="btn">Show Off My Badge</a>
        </div>
    </div>
</body>

</html>