<!DOCTYPE html>
<html>

<head>
    <style>
        body {
            font-family: sans-serif;
            background-color: #f4f4f4;
            padding: 20px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid #ddd;
        }

        .button {
            background: #4A6CF7;
            color: white;
            padding: 10px 20px;
            border-radius: 6px;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <div class="card">
        <h1>Welcome, <%= name %>!</h1>
        <p>Thanks for joining our store. Your account is now active.</p>
        <br />
        <a href="https://yourstore.com/profile" class="button">View Profile</a>
    </div>
</body>

</html>