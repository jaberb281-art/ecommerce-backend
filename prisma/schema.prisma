generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Port 6543 (Pooler)
  directUrl = env("DIRECT_URL")     // Port 5432 (Direct)
}

enum Role {
  USER
  ADMIN
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String?
  phone             String?
  username          String?            @unique
  role              Role               @default(USER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  cart              Cart?
  orders            Order[]
  addresses         Address[]
  userBadges        UserBadge[]
  userChallenges    UserChallenge[]
  notifications     Notification[]
  pointsBalance     Int                @default(0)
  pointTransactions PointTransaction[]
  profileBg         String?
  tokenVersion         Int       @default(0)
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
}

model Address {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  fullName  String
  phone     String
  building  String?
  block     String?
  street    String
  city      String
  state     String?
  zip       String?
  country   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String        @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int           @default(0)
  images      String[]
  status      ProductStatus @default(DRAFT)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Cart {
  id        String     @id @default(uuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([cartId, productId])
}

model Order {
  id                   String             @id @default(uuid())
  user                 User               @relation(fields: [userId], references: [id])
  userId               String
  items                OrderItem[]
  total                Float
  discount             Float?
  couponId             String?
  coupon               Coupon?            @relation(fields: [couponId], references: [id])
  addressId            String?
  address              Address?           @relation(fields: [addressId], references: [id])
  status               OrderStatus        @default(PENDING)
  idempotencyKey       String?            @unique
  isGift               Boolean            @default(false)
  giftMessage          String?
  giftSenderName       String?
  giftRecipientName    String?
  giftRecipientPhone   String?
  giftRecipientAddress String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  pointTransactions    PointTransaction[]
}

model OrderItem {
  id        String  @id @default(uuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  COMPLETED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  minOrderValue Float?
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  orders        Order[]
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  imageUrl    String?
  color       String?     @default("#000000")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userBadges  UserBadge[]
  challenges  Challenge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  awardedBy String?
  note      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

enum ChallengeType {
  BUY_PRODUCTS
  SPEND_AMOUNT
  PLACE_ORDERS
}

model Challenge {
  id             String          @id @default(uuid())
  name           String
  description    String?
  type           ChallengeType
  target         Float
  badgeId        String?
  badge          Badge?          @relation(fields: [badgeId], references: [id])
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userChallenges UserChallenge[]
}

model UserChallenge {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  progress    Float     @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

enum NotificationType {
  BADGE_AWARDED
  CHALLENGE_COMPLETED
  ORDER_UPDATE
  GENERAL
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventStatus {
  UPCOMING
  ONGOING
  PAST
  CANCELLED
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String?
  location    String
  venue       String?
  city        String      @default("Bahrain")
  startDate   DateTime
  endDate     DateTime?
  image       String?
  status      EventStatus @default(UPCOMING)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ShopSettings {
  id String @id @default("singleton")

  announcementSlides    Json
  announcementBgColor   String? @default("#18181b")
  announcementTextColor String? @default("#ffffff")

  heroImageUrl   String @default("https://placeholder.com/hero.jpg")
  heroTitle      String @default("Own Your Identity.")
  heroSubtitle   String @default("Handcrafted phone cases. Limited drops. Express your culture.")
  heroButtonText String @default("Shop Now")
  heroButtonLink String @default("/shop")

  bannerText      String  @default("🔥 Only 3 left! New designs dropping in 12h")
  isBannerVisible Boolean @default(true)
  bannerBgColor   String  @default("#FFF7ED")
  bannerTextColor String  @default("#C2410C")

  heroTagline     String  @default("New Arrivals")
  heroVisible     Boolean @default(true)
  heroShowProduct Boolean @default(true)

  bentoHotDealsLabel   String  @default("HOT DEALS")
  bentoHotDealsTag     String  @default("Most Popular")
  bentoHotDealsLink    String  @default("/shop?sort=best-sellers")
  bentoHotDealsVisible Boolean @default(true)

  bentoBestSellersLabel   String  @default("BEST SELLERS")
  bentoBestSellersTag     String  @default("Top Rated")
  bentoBestSellersLink    String  @default("/shop?sort=best-sellers")
  bentoBestSellersVisible Boolean @default(true)

  bentoNewArrivalsLabel   String  @default("NEW ARRIVALS")
  bentoNewArrivalsLink    String  @default("/shop?sort=newest")
  bentoNewArrivalsVisible Boolean @default(true)

  bentoCategoryTitle    String  @default("SHOP BY CATEGORY")
  bentoCategorySubtitle String  @default("Curated collections for your tech.")
  bentoSectionVisible   Boolean @default(true)

  catHeroTitle      String  @default("Shop By Category.")
  catHeroSubtitle   String  @default("Find exactly what you're looking for across our full range of premium mobile accessories and gadgets.")
  catHeroBadgeLabel String  @default("Browse All")
  catHeroVisible    Boolean @default(true)

  catTrustVisible Boolean @default(true)
  catTrustItems Json?

  catGridTitle    String @default("Explore Categories")
  catGridSubtitle String @default("Choose a category to discover our carefully curated products")

  catCtaVisible     Boolean @default(true)
  catCtaHeadline    String  @default("Can't find what you're looking for?")
  catCtaSubtext     String  @default("Browse all products in our shop")
  catCtaButtonLabel String  @default("View All Products")
  catCtaButtonLink  String  @default("/shop")

  // Profile card customisation
  profileBannerImages  Json   @default("[]")
  profileCardTagline  String? @default("Shbash Member")
  dashboardMessage String @default("Default message here")
  profileCardMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PointTxType {
  PURCHASE
  ORDER_MILESTONE
  CHALLENGE_REWARD
  SOCIAL_CONNECT
  REDEMPTION
  MANUAL
}

model PointTransaction {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        PointTxType
  description String?
  orderId     String?
  order       Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([orderId])
}

model AuthExchangeToken {
  id          String   @id @default(uuid())
  ticket      String   @unique
  accessToken String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
}
